# =========================
# Localhost Runtime
# =========================
BRACE_HOST=127.0.0.1
BRACE_BACKEND_PORT=8787
BRACE_ALLOWED_ORIGINS=http://127.0.0.1:5173,http://localhost:5173
BRACE_HTTP_BODY_LIMIT_BYTES=26214400
BRACE_HTTP_TIMEOUT_MS=90000
VITE_BRACE_API_BASE_URL=http://127.0.0.1:8787
# Optional: leave blank to use the same Windows roaming app data path as the desktop app.
BRACE_USER_DATA_DIR=

# =========================
# B.R.A.C.E AI Brain
# =========================
AI_PROVIDER=gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
GEMINI_FALLBACK_MODEL=gemini-2.5-flash-lite
GEMINI_TEMPERATURE=0.35
GEMINI_MAX_TOKENS=1200

# =========================
# Legacy Local AI
# =========================
ENABLE_LEGACY_LOCAL_AI=false
BRACE_OLLAMA_ENDPOINT=
BRACE_OLLAMA_MODEL=
BRACE_OPENAI_BASE_URL=
BRACE_OPENAI_MODEL=
BRACE_CUSTOM_ENDPOINT=

# =========================
# Firebase
# =========================
FIREBASE_ENABLED=false
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=
FIREBASE_DATABASE_URL=
FIREBASE_STORAGE_BUCKET=

# =========================
# Obsidian / B.R.A.C.E Brain
# =========================
OBSIDIAN_ENABLED=true
OBSIDIAN_VAULT_PATH=C:\Users\Admin\Documents\B.R.A.C.E-MAIN\BRACE-Brain
BRACE_BRAIN_PATH=C:\Users\Admin\Documents\B.R.A.C.E-MAIN\BRACE-Brain
OBSIDIAN_AUTO_CREATE=true

# =========================
# Kokoro Local TTS
# =========================
VOICE_TTS_PROVIDER=kokoro
BRACE_TTS_PROVIDER=kokoro
TTS_PROVIDER=kokoro
TTS_ENABLED=true
BRACE_KOKORO_HOST=127.0.0.1
BRACE_KOKORO_PORT=9787
BRACE_KOKORO_DEVICE=cpu
BRACE_KOKORO_STARTUP_TIMEOUT_MS=60000
BRACE_KOKORO_REQUEST_TIMEOUT_MS=30000

# =========================
# Optional Google Cloud TTS Fallback
# =========================
GOOGLE_TTS_FALLBACK_ENABLED=false
GOOGLE_APPLICATION_CREDENTIALS=
GOOGLE_CLOUD_PROJECT=
GOOGLE_TTS_LANGUAGE_CODE=en-US
GOOGLE_TTS_VOICE_NAME=en-US-Chirp-HD-F
GOOGLE_TTS_AUDIO_ENCODING=MP3
GOOGLE_TTS_SPEAKING_RATE=1.0
GOOGLE_TTS_PITCH=0
GOOGLE_TTS_VOLUME_GAIN_DB=0

# =========================
# Agent Limits
# =========================
MAX_TOOL_CALLS_PER_REQUEST=5
MAX_AGENT_STEPS=8
MAX_RETRIES=2
REQUEST_TIMEOUT_MS=60000
